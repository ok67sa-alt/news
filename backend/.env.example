# Backend environment template - copy to .env and configure
DATABASE_URL="postgresql://user:password@localhost:5432/sudan_times"
JWT_SECRET="your-secret-key-here-change-in-production"
NEXT_PUBLIC_TINYMCE_API_KEY=""

# ============================================
# FILE UPLOAD STORAGE (REQUIRED FOR PRODUCTION)
# ============================================
# Railway containers use ephemeral storage - files are deleted on restart!
# You MUST configure S3 or Cloudflare R2 for persistent storage.

# Option 1: AWS S3
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_KEY_PREFIX=uploads/
# S3_PUBLIC_URL=https://your-bucket.s3.us-east-1.amazonaws.com/

# Option 2: Cloudflare R2 (Recommended - Free 10GB)
# S3_BUCKET=your-r2-bucket-name
# S3_REGION=auto
# AWS_ACCESS_KEY_ID=your-r2-access-key-id
# AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key
# S3_KEY_PREFIX=uploads/
# S3_PUBLIC_URL=https://your-bucket.your-account.r2.cloudflarestorage.com/
