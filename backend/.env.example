# Backend environment template - copy to .env and configure

# ============================================
# DATABASE CONFIGURATION (MySQL for Hostinger)
# ============================================
# MySQL Connection String Format:
# DATABASE_URL="mysql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME"
# 
# Example for Hostinger:
# DATABASE_URL="mysql://u123456789_sudanuser:YourPassword@localhost:3306/u123456789_sudantimes"
#
# For local development with MySQL:
# DATABASE_URL="mysql://root:password@localhost:3306/sudan_times"
DATABASE_URL="mysql://user:password@localhost:3306/sudan_times"

# JWT Secret for authentication (change in production!)
JWT_SECRET="your-secret-key-here-change-in-production"

# TinyMCE API Key (optional, for rich text editor)
NEXT_PUBLIC_TINYMCE_API_KEY=""

# ============================================
# FILE UPLOAD STORAGE (REQUIRED FOR PRODUCTION)
# ============================================

# Cloudinary Configuration (Recommended - Free 25GB)
CLOUDINARY_CLOUD_NAME="utdfxckm"
CLOUDINARY_API_KEY="742197721758692"
CLOUDINARY_API_SECRET="JSiuuOoTEN_jf-mLcNEZp-HUK7o"
CLOUDINARY_FOLDER="sudan-news"  # Optional: organize uploads in a folder

# Legacy S3/R2 Configuration (if you prefer S3 over Cloudinary)
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_KEY_PREFIX=uploads/
# S3_PUBLIC_URL=https://your-bucket.s3.us-east-1.amazonaws.com/
